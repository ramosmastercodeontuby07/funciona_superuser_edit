<!-- app/views/finance/index.html.erb -->
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Panel de Finanzas</title>
  <%= csrf_meta_tags %>
  <style>
    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; margin:0; color:#111; background:#f5f6f8; }
    .wrap { max-width: 1200px; margin: 0 auto; padding: 20px; }
    .topbar { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
    .title { font-size:22px; font-weight:800; }
    .btn { display:inline-flex; align-items:center; gap:6px; padding:10px 14px; border-radius:12px; border:1px solid rgba(0,0,0,.12); background:#fff; color:#111; text-decoration:none; }
    .grid { display:grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap:12px; }
    .card { background: rgba(255,255,255,0.8); border:1px solid rgba(0,0,0,.08); border-radius:16px; padding:16px; backdrop-filter: blur(4px); }
    .kpi { display:flex; flex-direction:column; gap:6px; }
    .kpi .label { color:#555; font-size:12px; text-transform:uppercase; letter-spacing:.08em; }
    .kpi .value { font-size:22px; font-weight:800; }
    .section { margin-top:16px; }
    table { width:100%; border-collapse:separate; border-spacing:0; }
    th, td { padding:10px 12px; border-bottom:1px solid rgba(0,0,0,.08); white-space:nowrap; }
    th { text-align:left; color:#333; background:rgba(255,255,255,.7); position:sticky; top:0; }
    .table-card { max-height: 420px; overflow:auto; }
    .muted { color:#666; }
  </style>
</head>
<body>
<div class="wrap">
  <div class="topbar">
    <div class="title">Panel de Finanzas</div>
    <div class="actions">
      <%= link_to 'Inicio', ecommerce_path, class: 'btn' %>
      <%# Podrías agregar exportar CSV, etc. %>
    </div>
  </div>

  <!-- KPIs -->
  <div class="grid">
    <div class="card kpi"><div class="label">Clientes registrados</div><div class="value"><%= @customers_total %></div></div>
    <div class="card kpi"><div class="label">Órdenes hoy</div><div class="value"><%= @orders_today_count %></div></div>
    <div class="card kpi"><div class="label">Ventas hoy</div><div class="value">$<%= sprintf('%.2f', @sales_today_total) %></div></div>
    <div class="card kpi"><div class="label">Utilidad hoy</div><div class="value">$<%= sprintf('%.2f', @profit_today) %></div></div>
  </div>

  <div class="grid section">
    <div class="card kpi"><div class="label">Ventas semana</div><div class="value">$<%= sprintf('%.2f', @sales_week_total) %></div></div>
    <div class="card kpi"><div class="label">Utilidad semana</div><div class="value">$<%= sprintf('%.2f', @profit_week) %></div></div>
    <div class="card kpi"><div class="label">Ventas mes</div><div class="value">$<%= sprintf('%.2f', @sales_month_total) %></div></div>
    <div class="card kpi"><div class="label">Utilidad año</div><div class="value">$<%= sprintf('%.2f', @profit_year) %></div></div>
  </div>

  <!-- Top productos por utilidad (últimos 30 días) -->
  <div class="section card table-card">
    <div class="label" style="margin-bottom:8px;">Top productos por utilidad (últimos 30 días)</div>
    <table>
      <thead><tr><th>Producto</th><th>Cantidad</th><th>Ventas</th><th>Utilidad</th></tr></thead>
      <tbody>
      <% @top_products.each do |p| %>
        <tr>
          <td><%= p.name %></td>
          <td class="muted"><%= p.qty %></td>
          <td>$<%= sprintf('%.2f', p.revenue) %></td>
          <td><strong>$<%= sprintf('%.2f', p.profit) %></strong></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>

  <!-- Resumen mensual por producto (últimos 12 meses) -->
  <div class="section card table-card">
    <div class="label" style="margin-bottom:8px;">Resumen mensual por producto (12 meses)</div>
    <table>
      <thead><tr><th>Mes</th><th>Producto</th><th>Cant.</th><th>Ventas</th><th>Utilidad</th></tr></thead>
      <tbody>
      <% @monthly_product_summary.each do |row| %>
        <% month_label = row[:month].strftime('%b %Y') %>
        <% row[:products].each do |prod| %>
          <tr>
            <td class="muted"><%= month_label %></td>
            <td><%= prod[:name] %></td>
            <td class="muted"><%= prod[:qty] %></td>
            <td>$<%= sprintf('%.2f', prod[:revenue]) %></td>
            <td><strong>$<%= sprintf('%.2f', prod[:profit]) %></strong></td>
          </tr>
        <% end %>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
</body>
</html>
