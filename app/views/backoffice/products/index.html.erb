<!-- app/views/backoffice/products/index.html.erb -->
<style>
  /* Scroll y tabla */
  .backoffice-scroll {
    max-height: calc(100vh - 230px);
    overflow-y: auto;
    overflow-x: auto;
    border: 1px solid rgba(0,0,0,.2);
    border-radius: 12px;
    background: transparent; /* transparente */
  }
  .backoffice-table {
    width: 100%;
    min-width: 1000px;
    border-collapse: separate;
    border-spacing: 0;
    color: #111; /* letras negras */
  }
  .backoffice-table thead th {
    position: sticky;
    top: 0;
    background: transparent; /* header transparente */
    z-index: 1;
    border-bottom: 1px solid rgba(0,0,0,.15);
  }
  .backoffice-table th,
  .backoffice-table td {
    padding: 10px 12px;
    white-space: nowrap;
    border-bottom: 1px solid rgba(0,0,0,.08);
  }
  .backoffice-table img {
    height: 64px; width: auto; border-radius: 8px; display: block;
  }
</style>

<div class="container mx-auto px-4 py-6" style="color:#111;">
  <div class="flex items-center justify-between mb-4">
    <h1 class="text-2xl font-bold">Productos (Backoffice)</h1>
    <div class="flex gap-2">
      <%= link_to "Inicio", ecommerce_path, class: "btn btn-dark" %>
      <%= link_to "Nuevo producto", new_backoffice_product_path, class: "btn btn-primary" %>
    </div>
  </div>

  <% if notice %><div class="alert alert-success mb-4"><%= notice %></div><% end %>
  <% if alert  %><div class="alert alert-warning mb-4"><%= alert %></div><% end %>

  <div class="backoffice-scroll">
    <table class="backoffice-table">
      <thead>
        <tr>
          <th>Imagen</th>
          <th>Nombre</th>
          <th>Precio</th>
          <th>Stock</th>
          <th>Sección</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |p| %>
          <tr>
            <td>
              <% if p.image.attached? %>
                <%= image_tag p.image.variant(resize_to_limit: [80, 80]), alt: p.name %>
              <% else %>
                <span class="text-gray-600">Sin imagen</span>
              <% end %>
            </td>
            <td><%= p.name %></td>
            <td>$<%= number_with_precision(p.price, precision: 2) %></td>
            <td><%= p.stock %></td>
            <td><%= p.product_section_label %></td>
            <td>
              <% if p.active? %>
                <span class="font-semibold" style="color:#15803d">Activo</span>
              <% else %>
                <span class="font-semibold" style="color:#b91c1c">Inactivo</span>
              <% end %>
            </td>
            <td class="space-x-2">
              <%= link_to "Editar", edit_backoffice_product_path(p), class: "btn btn-sm" %>
              <%= link_to "Eliminar",
                          backoffice_product_path(p),
                          data: { turbo_method: :delete, turbo_confirm: "¿Eliminar #{p.name}?" },
                          class: "btn btn-sm btn-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
