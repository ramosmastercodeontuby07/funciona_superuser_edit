<!-- app/views/backoffice/staff_users/new.html.erb -->
<% content_for :title, "Crear usuario de Staff" %>

<div class="panel shop-panel">
  <div class="shop-header" style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
    <h2>Crear usuario de Staff</h2>
    <div class="header-actions">
      <%= link_to "Usuarios (Backoffice)", backoffice_staff_users_path, class: "btn btn-light" %>
      <%= link_to "Productos", backoffice_products_path, class: "btn btn-light" %>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="alert"><%= flash[:notice] %></div>
  <% end %>

  <% if flash[:alert] %>
    <div class="alert"><%= flash[:alert] %></div>
  <% end %>

  <div class="card">
    <% if @user&.errors&.any? %>
      <div class="alert">
        <strong><%= pluralize(@user.errors.count, "error") %>:</strong>
        <ul style="margin:.5rem 0 0 1rem;">
          <% @user.errors.full_messages.each do |m| %>
            <li><%= m %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user,
                  url: backoffice_staff_users_path,
                  local: true,
                  html: { enctype: "multipart/form-data" } do |f| %>

      <div class="form-group">
        <label for="user_name">Nombre (usuario)</label>
        <%= f.text_field :name, required: true, autofocus: true, class: "form-input" %>
      </div>

      <div class="form-group">
        <label for="user_password">Contraseña</label>
        <%= f.password_field :password, required: true, class: "form-input" %>
      </div>

      <div class="form-group">
        <label for="user_password_confirmation">Confirmar contraseña</label>
        <%= f.password_field :password_confirmation, class: "form-input" %>
      </div>

      <div class="form-group">
        <label for="user_photo">Foto (opcional)</label>
        <%= f.file_field :photo, accept: "image/png,image/jpg,image/jpeg", class: "form-input" %>
      </div>

      <div class="form-group">
        <label for="user_superuser">¿Es superusuario?</label>
        <%= check_box_tag "user[superuser]",
                          "1",
                          (@user&.superuser? || false),
                          id: "user_superuser" %>
        <p class="help-text">Si está marcado, se asignará el rol <code>superuser</code>.</p>
      </div>

      <div class="form-group">
        <label for="user_secret_code">Secret code (requerido si es superusuario)</label>
        <%= f.password_field :secret_code, class: "form-input", id: "user_secret_code" %>
      </div>

      <hr>

      <div class="footer-buttons">
        <%= f.submit "Crear usuario", class: "btn btn-accent" %>
        <%= link_to "Cancelar", backoffice_staff_users_path, class: "btn btn-light" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cb = document.getElementById('user_superuser');
    const sc = document.getElementById('user_secret_code');
    function toggleSecretCodeRequired() {
      if (!cb || !sc) return;
      if (cb.checked) {
        sc.setAttribute('required', 'required');
      } else {
        sc.removeAttribute('required');
      }
    }
    cb?.addEventListener('change', toggleSecretCodeRequired);
    toggleSecretCodeRequired();
  });
</script>
