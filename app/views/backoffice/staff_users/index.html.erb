<div class="container mx-auto px-4 py-6" style="color:#111;">
  <div class="flex items-center justify-between mb-4">
    <h1 class="text-2xl font-bold">Usuarios Staff (Backoffice)</h1>
    <div class="flex gap-2">
      <%= link_to "Inicio", ecommerce_path, class: "btn btn-dark" %>
      <%= link_to "Nuevo usuario", new_backoffice_staff_user_path, class: "btn btn-primary" %>
      <%= link_to "Productos", backoffice_products_path, class: "btn" %>
    </div>
  </div>

  <% if notice %><div class="alert alert-success mb-4"><%= notice %></div><% end %>
  <% if alert  %><div class="alert alert-warning mb-4"><%= alert %></div><% end %>

  <div class="backoffice-scroll">
    <table class="backoffice-table">
      <thead>
        <tr>
          <th>Foto</th>
          <th>Nombre</th>
          <th>Rol</th>
          <th>Creado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |u| %>
          <tr>
            <td>
              <% if u.photo.attached? %>
                <%= image_tag u.photo.variant(resize_to_limit: [80, 80]), alt: u.name %>
              <% else %>
                <span class="text-gray-600">Sin foto</span>
              <% end %>
            </td>
            <td><%= u.name %></td>
            <td><%= u.superuser? ? "Superuser" : "Normal" %></td>
            <td><%= u.created_at.in_time_zone("America/Merida").strftime("%Y-%m-%d %H:%M") %></td>
            <td class="space-x-2">
              <%= link_to "Editar", edit_backoffice_staff_user_path(u), class: "btn btn-sm" %>
              <%= link_to "Eliminar",
                          backoffice_staff_user_path(u),
                          data: { turbo_method: :delete, turbo_confirm: "¿Eliminar #{u.name}?" },
                          class: "btn btn-sm btn-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
